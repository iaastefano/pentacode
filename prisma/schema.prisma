generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id           String   @id @default(cuid())
  title        String
  description  String
  url          String?
  technologies String // JSON array as string
  images       String // JSON array of image URLs
  order        Int      @default(0)
  visible      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String?
  photo     String?
  text      String
  rating    Int      @default(5)
  videoUrl  String?
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id          String        @id @default(cuid())
  clientName  String?
  clientEmail String?
  messages    ChatMessage[]
  status      String        @default("active")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime    @default(now())
}

model QuoteRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  description String?
  audioPath   String?
  status      String   @default("new")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model SiteSettings {
  id               String   @id @default("default")
  projectsCount    Int      @default(50)
  clientsCount     Int      @default(30)
  satisfactionRate Int      @default(99)
  updatedAt        DateTime @updatedAt
}
